{
  "version": 2,
  "builds": [
    { "src": "backend/src/main.ts", "use": "@vercel/node" },
    { "src": "frontend/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/src/main.ts" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}